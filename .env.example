# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit .env. Secrets are read ONLY from env.
# The system boots fully in `paper` mode with NONE of these set.
# ---------------------------------------------------------------------------

# --- Run mode -------------------------------------------------------------
# paper = simulate fills locally (DEFAULT, safe).
# demo  = Kalshi sandbox/demo environment (mock funds).
# live  = REAL money. Requires BOTH WCK_MODE=live AND WCK_ALLOW_LIVE=true
#         AND execution.live_confirmed: true in config. Otherwise startup fails.
WCK_MODE=paper
WCK_ALLOW_LIVE=false

# --- Kalshi API (only needed for demo/live) -------------------------------
# Create an API key in the Kalshi dashboard. You get a Key ID + an RSA private key
# (PEM). The private key is shown ONCE. Store the PEM file outside the repo.
KALSHI_API_KEY_ID=
# Provide the key as EITHER a path to the PEM file ...
KALSHI_PRIVATE_KEY_PATH=
# ... OR the PEM contents inline (use one or the other, path takes precedence).
KALSHI_PRIVATE_KEY_PEM=

# --- Football data provider (only needed for live ingestion) --------------
# Default provider is `simulated` (no key). Set football.provider in config to
# `apifootball` or `thestatsapi` and supply the matching key below.
APIFOOTBALL_KEY=
THESTATSAPI_KEY=

# --- Alerts (optional) ----------------------------------------------------
# If set, priority events (goal, red card, divergence, guardrail trip) POST here.
ALERTS_WEBHOOK_URL=
# Phone/chat notifications (enable the matching channel in config: alerts.*).
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email alerts (alerts.email: true). Uses STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Config file override (optional) --------------------------------------
# Point at an alternate YAML config. Defaults to config/default.yaml (+ optional
# config/local.yaml overlay if present).
WCK_CONFIG=
